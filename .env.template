# =============================================================================
# APNS — Apple Push Notification Service
# =============================================================================

# Key ID generated in the Apple Developer portal
# Example: ABCD123456
APNS_KEY_ID=

# Team ID from your Apple Developer account
# Example: TEAM000001
APNS_TEAM_ID=

# Bundle ID of the iOS app that will receive notifications
# Example: com.example.myapp
APNS_BUNDLE_ID=

# Private key content from the .p8 file (PEM, not a file path)
# Generated at: Apple Developer → Certificates, Identifiers & Profiles → Keys
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
<paste your .p8 key content here>
-----END PRIVATE KEY-----"

# Set to "true" for production, "false" for sandbox (development)
APNS_PRODUCTION=false

# =============================================================================
# Mempool Network
# =============================================================================

# Bitcoin network to monitor: "mainnet" (default) or "signet"
MEMPOOL_NETWORK=mainnet
